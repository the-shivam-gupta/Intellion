BASE_URL=https://webapi.intellion.in/wp-json/intellion/v1

# VAPT 3.5: browser encrypts form data -> Nuxt decrypts -> WordPress API (no backend change).
# Public key:  static/encryption-public.pem  (must be committed and deployed)
# Private key: encryption-private.pem on server only (NOT committed)
# Optional:    ENCRYPTION_PUBLIC_KEY / ENCRYPTION_PRIVATE_KEY in .env with \n line breaks

# If dev still shows "unable to verify the first certificate", the API cert chain
# may be incomplete on the server, or your network uses a custom CA. Fix the API
# SSL cert for production; dev uses relaxed TLS only when NODE_ENV=development.
